# Required for transcription and AI clip selection.
OPENAI_API_KEY=

# Optional model overrides.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
OPENAI_ANALYSIS_MODEL=gpt-5

# Set this to the deployed URL so social preview image links resolve correctly.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development only: opt in when specifically testing persisted rate limits.
CIRCUMVISION_ENFORCE_LOCAL_RATE_LIMITS=false

# Optional lifecycle policy. Finished projects and source media remain until the
# owner deletes them. Failed/cancelled and abandoned uploads are cleaned up.
CIRCUMVISION_FAILED_RETENTION_DAYS=14
CIRCUMVISION_ABANDONED_UPLOAD_DAYS=7

# Optional. Two parallel three-minute transcript sections keep 35–40 minute
# sermons inside Netlify's background window without excessive API concurrency.
CIRCUMVISION_TRANSCRIPTION_CONCURRENCY=2

# Optional external media-worker adapter for workloads that exceed the hosting
# provider's background execution window. Keep all values secret.
CIRCUMVISION_WORKER_URL=
CIRCUMVISION_WORKER_TOKEN=
CIRCUMVISION_BLOB_SITE_ID=
CIRCUMVISION_BLOB_TOKEN=
